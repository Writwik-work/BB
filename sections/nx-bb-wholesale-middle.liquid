{{ 'nx-bb-wholesale-middle.css' | asset_url | stylesheet_tag }}

<section id="section-{{ section.id }}" class="nx-bb-wholesale-middle section-{{ section.id }}-padding">
  <div class="nx-bb-wholesale-middle__inner">

    {% if section.settings.heading != blank %}
      <h1 class="nx-bb-wholesale-middle__title">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.intro != blank %}
      <div class="nx-bb-wholesale-middle__intro rte">{{ section.settings.intro }}</div>
    {% endif %}

    {% if section.settings.benefits_heading != blank %}
      <h2 class="nx-bb-wholesale-middle__subheading">{{ section.settings.benefits_heading }}</h2>
    {% endif %}

    <div class="nx-bb-wholesale-middle__benefits">
      {% for i in (1..3) %}
        {% assign icon_key = 'benefit_' | append: i | append: '_icon' %}
        {% assign title_key = 'benefit_' | append: i | append: '_title' %}
        {% assign text_key = 'benefit_' | append: i | append: '_text' %}

        <div class="nx-bb-wholesale-middle__benefit">
          {% if section.settings[icon_key] != blank %}
            <div class="nx-bb-wholesale-middle__icon">
              <img
                src="{{ section.settings[icon_key] | image_url: width: 160 }}"
                width="64"
                height="64"
                loading="lazy"
                alt="{{ section.settings[title_key] | escape }}"
              >
            </div>
          {% endif %}

          {% if section.settings[title_key] != blank %}
            <div class="nx-bb-wholesale-middle__benefit-title">{{ section.settings[title_key] }}</div>
          {% endif %}

          {% if section.settings[text_key] != blank %}
            <div class="nx-bb-wholesale-middle__benefit-text rte">{{ section.settings[text_key] }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.criteria_heading != blank %}
      <h3 class="nx-bb-wholesale-middle__criteria-title">{{ section.settings.criteria_heading }}</h3>
    {% endif %}

    {% if section.settings.criteria_list != blank %}
      <div class="nx-bb-wholesale-middle__criteria rte">{{ section.settings.criteria_list }}</div>
    {% endif %}

    {% if section.settings.footer_line != blank %}
      <div class="nx-bb-wholesale-middle__footer rte">{{ section.settings.footer_line }}</div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "NX BB - Wholesale Middle",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Main heading", "default": "JOIN THE BEARDED BUTCHER WHOLESALE FAMILY" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>If you’re interested in selling our products in your brick-and-mortar or online store and are located within the continental United States, visit <a href=\"https://wholesale.beardedbutchers.com\" target=\"_blank\" rel=\"noopener\">wholesale.beardedbutchers.com</a>.</p>" },

    { "type": "text", "id": "benefits_heading", "label": "Benefits heading", "default": "BENEFITS OF PARTNERING" },

    { "type": "image_picker", "id": "benefit_1_icon", "label": "Benefit 1 icon" },
    { "type": "text", "id": "benefit_1_title", "label": "Benefit 1 title", "default": "COMPETITIVE WHOLESALE PRICING" },
    { "type": "richtext", "id": "benefit_1_text", "label": "Benefit 1 text", "default": "<p>Enjoy substantial discounts beyond the standard 5% or 10%</p>" },

    { "type": "image_picker", "id": "benefit_2_icon", "label": "Benefit 2 icon" },
    { "type": "text", "id": "benefit_2_title", "label": "Benefit 2 title", "default": "FREE SHIPPING" },
    { "type": "richtext", "id": "benefit_2_text", "label": "Benefit 2 text", "default": "<p>Complimentary shipping on orders over $500</p>" },

    { "type": "image_picker", "id": "benefit_3_icon", "label": "Benefit 3 icon" },
    { "type": "text", "id": "benefit_3_title", "label": "Benefit 3 title", "default": "DEDICATED CUSTOMER SUPPORT" },
    { "type": "richtext", "id": "benefit_3_text", "label": "Benefit 3 text", "default": "<p>Access to our responsive customer service team for all inquiries</p>" },

    { "type": "text", "id": "criteria_heading", "label": "Criteria heading", "default": "TO BE ELIGIBLE, YOU MUST MEET THE FOLLOWING CRITERIA:" },
    { "type": "richtext", "id": "criteria_list", "label": "Criteria list", "default": "<ul><li>You have a verifiable online or brick and mortar store that is in a comparable niche. For example, if you have a Shopify clothing store, you would not be eligible.</li><li>If you have a store in Canada and would like to sell our products, please click here to visit our Canadian partner and get set up with them for wholesale distribution in Canada.</li><li>Your store is verifiable. We must be able to find your online store through a link or your B&M store with a simple address search.</li><li>You have the authority to sell the products in the store. If you are the owner, this is easy. If you have another position in the company, we may need to verify that you have the authority to sell the products in the store.</li></ul>" },
    { "type": "richtext", "id": "footer_line", "label": "Bottom line", "default": "<p>If you have any questions about our program, simply reach out to <a href=\"mailto:wholesale@beardedbutchers.com\">wholesale@beardedbutchers.com</a></p>" },

    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 48 }
  ],
  "presets": [{ "name": "NX BB - Wholesale Middle" }]
}
{% endschema %}

{% style %}
  #section-{{ section.id }}.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 749px) {
    #section-{{ section.id }}.section-{{ section.id }}-padding {
      padding-top: calc({{ section.settings.padding_top }}px * 0.75);
      padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.75);
    }
  }
{% endstyle %}
