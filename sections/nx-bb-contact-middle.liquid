{{ 'nx-bb-contact-middle.css' | asset_url | stylesheet_tag }}

<section id="section-{{ section.id }}" class="nx-bb-contact section-{{ section.id }}-padding">
  <div class="nx-bb-contact__inner">
    {% if section.settings.heading != blank %}
      <h1 class="nx-bb-contact__title">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <div class="nx-bb-contact__subtext rte">
        {{ section.settings.subtext }}
      </div>
    {% endif %}

    <div class="nx-bb-contact__form-wrap">
      {% form 'contact', id: 'ContactForm', class: 'nx-bb-contact__form' %}
        {%- if form.posted_successfully? -%}
          <p class="nx-bb-contact__success">{{ section.settings.success_text }}</p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="nx-bb-contact__errors">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="nx-bb-contact__field">
          <label for="ContactForm-name">{{ section.settings.label_name }}</label>
          <input
            type="text"
            id="ContactForm-name"
            name="contact[name]"
            value="{% if form.name %}{{ form.name }}{% endif %}"
            autocomplete="name"
          >
        </div>

        <div class="nx-bb-contact__field">
          <label for="ContactForm-email">{{ section.settings.label_email }}</label>
          <input
            type="email"
            id="ContactForm-email"
            name="contact[email]"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            autocapitalize="off"
            autocomplete="email"
            required
          >
        </div>

        <div class="nx-bb-contact__field">
          <label for="ContactForm-body">{{ section.settings.label_message }}</label>
          <textarea
            rows="7"
            id="ContactForm-body"
            name="contact[body]"
            required
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>

        <button type="submit" class="nx-bb-contact__btn">
          {{ section.settings.button_text }}
        </button>
      {% endform %}
    </div>

    <div class="nx-bb-contact__info">
      {%- if section.blocks.size > 0 -%}
        {% for block in section.blocks %}
          {% if block.type == 'info' %}
            <div class="nx-bb-contact__info-item" {{ block.shopify_attributes }}>
              <div class="nx-bb-contact__info-head">
                <span class="nx-bb-contact__info-icon" aria-hidden="true">
                  {{ section.settings.icon_svg }}
                </span>
                <h3 class="nx-bb-contact__info-title">{{ block.settings.title }}</h3>
              </div>

              {% if block.settings.text != blank %}
                <div class="nx-bb-contact__info-text rte">{{ block.settings.text }}</div>
              {% endif %}

              {% if block.settings.link_url != blank %}
                <a class="nx-bb-contact__info-link" href="{{ block.settings.link_url }}">
                  {{ block.settings.link_label }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      {%- else -%}
        <div class="nx-bb-contact__info-item">
          <div class="nx-bb-contact__info-head">
            <span class="nx-bb-contact__info-icon" aria-hidden="true">{{ section.settings.icon_svg }}</span>
            <h3 class="nx-bb-contact__info-title">{{ section.settings.info_1_title }}</h3>
          </div>
          <div class="nx-bb-contact__info-text rte">{{ section.settings.info_1_text }}</div>
        </div>

        <div class="nx-bb-contact__info-item">
          <div class="nx-bb-contact__info-head">
            <span class="nx-bb-contact__info-icon" aria-hidden="true">{{ section.settings.icon_svg }}</span>
            <h3 class="nx-bb-contact__info-title">{{ section.settings.info_2_title }}</h3>
          </div>
          <div class="nx-bb-contact__info-text rte">{{ section.settings.info_2_text }}</div>
        </div>

        <div class="nx-bb-contact__info-item">
          <div class="nx-bb-contact__info-head">
            <span class="nx-bb-contact__info-icon" aria-hidden="true">{{ section.settings.icon_svg }}</span>
            <h3 class="nx-bb-contact__info-title">{{ section.settings.info_3_title }}</h3>
          </div>
          <div class="nx-bb-contact__info-text rte">{{ section.settings.info_3_text }}</div>
        </div>

        <div class="nx-bb-contact__info-item">
          <div class="nx-bb-contact__info-head">
            <span class="nx-bb-contact__info-icon" aria-hidden="true">{{ section.settings.icon_svg }}</span>
            <h3 class="nx-bb-contact__info-title">{{ section.settings.info_4_title }}</h3>
          </div>
          <div class="nx-bb-contact__info-text rte">{{ section.settings.info_4_text }}</div>
        </div>

        <div class="nx-bb-contact__info-item">
          <div class="nx-bb-contact__info-head">
            <span class="nx-bb-contact__info-icon" aria-hidden="true">{{ section.settings.icon_svg }}</span>
            <h3 class="nx-bb-contact__info-title">{{ section.settings.info_5_title }}</h3>
          </div>
          <div class="nx-bb-contact__info-text rte">{{ section.settings.info_5_text }}</div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NX BB - Contact Middle",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "GET IN TOUCH" },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>If you have a question about your order or anything related to www.beardedbutchers.com, please submit the contact form below. We typically respond within 1-2 business days.</p>"
    },

    { "type": "text", "id": "label_name", "label": "Name label", "default": "Name" },
    { "type": "text", "id": "label_email", "label": "Email label", "default": "Email" },
    { "type": "text", "id": "label_message", "label": "Message label", "default": "Message" },

    { "type": "text", "id": "button_text", "label": "Button text", "default": "SUBMIT" },
    {
      "type": "text",
      "id": "success_text",
      "label": "Success message",
      "default": "Thanks! We’ve received your message."
    },

    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#7b3b2f" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" },

    {
      "type": "textarea",
      "id": "icon_svg",
      "label": "Info icon SVG",
      "default": "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5Z\" fill=\"#111\"/></svg>"
    },

    {
      "type": "header",
      "content": "Default info content"
    },

    { "type": "text", "id": "info_1_title", "label": "Info 1 title", "default": "CUSTOMER SERVICE" },
    {
      "type": "richtext",
      "id": "info_1_text",
      "label": "Info 1 text",
      "default": "<p>For inquiries regarding orders or products on our website, contact:</p><p><strong>Email:</strong> customerservice@beardedbutchers.com</p><p>Please do not call Whitefeather Meats for any Bearded Butchers online order-related questions.</p>"
    },

    { "type": "text", "id": "info_2_title", "label": "Info 2 title", "default": "MARKETING & PROMOTIONAL REQUESTS" },
    {
      "type": "richtext",
      "id": "info_2_text",
      "label": "Info 2 text",
      "default": "<p>For marketing or promotional requests, reach out to:</p><p><strong>Email:</strong> marketing@beardedbutchers.com</p>"
    },

    { "type": "text", "id": "info_3_title", "label": "Info 3 title", "default": "PARTNERSHIP OPPORTUNITIES" },
    {
      "type": "richtext",
      "id": "info_3_text",
      "label": "Info 3 text",
      "default": "<p>Interested in becoming a product or media partner with The Bearded Butchers?</p><p><strong>Email:</strong> partnerships@beardedbutchers.com</p>"
    },

    { "type": "text", "id": "info_4_title", "label": "Info 4 title", "default": "WHITEFEATHER MEATS RETAIL STORE" },
    {
      "type": "richtext",
      "id": "info_4_text",
      "label": "Info 4 text",
      "default": "<p>Visit <strong>Whitefeather Meats</strong> for information on our brick-and-mortar store in Creston, Ohio.</p>"
    },

    { "type": "text", "id": "info_5_title", "label": "Info 5 title", "default": "BEARDED BUTCHER FULFILLMENT CENTER" },
    {
      "type": "richtext",
      "id": "info_5_text",
      "label": "Info 5 text",
      "default": "<p><strong>Location:</strong> Creston, OH 44691</p>"
    },

    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "info",
      "name": "Info block",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "CUSTOMER SERVICE" },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>For inquiries regarding orders or products on our website, contact:</p><p><strong>Email:</strong> customerservice@beardedbutchers.com</p>"
        },
        { "type": "text", "id": "link_label", "label": "Link label (optional)", "default": "Learn more" },
        { "type": "url", "id": "link_url", "label": "Link URL (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "NX BB - Contact Middle",
      "blocks": [{ "type": "info" }, { "type": "info" }, { "type": "info" }, { "type": "info" }, { "type": "info" }]
    }
  ]
}
{% endschema %}
