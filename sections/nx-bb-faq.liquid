{{ 'nx-bb-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'nx-bb-faq.js' | asset_url }}" defer></script>

<section
  id="section-{{ section.id }}"
  class="nx-bb-faq section-{{ section.id }}-padding"
  style="
    --nxbb-faq-bg: {{ section.settings.bg_color }};
    --nxbb-faq-text: {{ section.settings.text_color }};
    --nxbb-faq-divider: {{ section.settings.divider_color }};
    --nxbb-faq-icon: {{ section.settings.icon_color }};
    --nxbb-faq-width: {{ section.settings.content_width }}px;
  "
>
  <div class="nx-bb-faq__inner">
    <div class="nx-bb-faq__header">
      {% if section.settings.heading != blank %}
        <h1 class="nx-bb-faq__title">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="nx-bb-faq__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="nx-bb-faq__list" data-nxbb-faq>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          <div class="nx-bb-faq__row" {{ block.shopify_attributes }}>
            <button
              type="button"
              class="nx-bb-faq__trigger"
              aria-expanded="false"
              aria-controls="nxbb-faq-panel-{{ section.id }}-{{ block.id }}"
            >
              <span class="nx-bb-faq__q">{{ block.settings.question | escape }}</span>
              <span class="nx-bb-faq__plus" aria-hidden="true"></span>
            </button>

            <div
              id="nxbb-faq-panel-{{ section.id }}-{{ block.id }}"
              class="nx-bb-faq__panel"
              hidden
            >
              <div class="nx-bb-faq__a rte">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.contact_link != blank and section.settings.contact_link_text != blank %}
      <div class="nx-bb-faq__bottom">
        {% if section.settings.contact_text != blank %}
          <span class="nx-bb-faq__bottom-text">{{ section.settings.contact_text }}</span>
        {% endif %}
        <a class="nx-bb-faq__bottom-link" href="{{ section.settings.contact_link }}">
          {{ section.settings.contact_link_text }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "NX BB - FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "FAQs" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Find quick answers to common questions." },

    { "type": "range", "id": "content_width", "label": "Content max width (px)", "min": 520, "max": 980, "step": 20, "default": 860 },

    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "color", "id": "divider_color", "label": "Divider color", "default": "#e9e9e9" },
    { "type": "color", "id": "icon_color", "label": "Plus/Minus icon color", "default": "#111111" },

    { "type": "text", "id": "contact_text", "label": "Bottom line text", "default": "Still Have Questions?" },
    { "type": "text", "id": "contact_link_text", "label": "Bottom link text", "default": "Contact Us" },
    { "type": "url", "id": "contact_link", "label": "Bottom link URL" },

    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding bottom", "default": 48 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What can I use these seasonings on?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Add your answer here.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "NX BB - FAQ",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}

{% style %}
  #section-{{ section.id }}.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 749px) {
    #section-{{ section.id }}.section-{{ section.id }}-padding {
      padding-top: calc({{ section.settings.padding_top }}px * 0.75);
      padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.75);
    }
  }
{% endstyle %}
