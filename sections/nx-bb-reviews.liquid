{{ 'nx-bb-reviews.css' | asset_url | stylesheet_tag }}

<section
  id="section-{{ section.id }}"
  class="nx-bb-reviews section-{{ section.id }}-padding"
  style="
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="page-width nx-bb-reviews__inner">
    {% if section.settings.heading != blank %}
      <h2 class="nx-bb-reviews__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {%- comment -%} SUMMARY BAR (score, histogram, total reviews) {%- endcomment -%}
    <div class="nx-bb-reviews__summary-row">
      <div class="nx-bb-reviews__score">
        <div class="nx-bb-reviews__score-stars">★★★★★</div>
        <div class="nx-bb-reviews__score-line">
          {{ section.settings.rating_line }}
        </div>
        <div class="nx-bb-reviews__score-subline">
          {{ section.settings.rating_subline }}
        </div>
      </div>

      <div class="nx-bb-reviews__histogram">
        {% assign total_hist = section.settings.bar_5
          | plus: section.settings.bar_4
          | plus: section.settings.bar_3
          | plus: section.settings.bar_2
          | plus: section.settings.bar_1
        %}
        {% if total_hist == 0 %}
          {% assign total_hist = 1 %}
        {% endif %}

        {% assign total_hist = section.settings.bar_5
          | plus: section.settings.bar_4
          | plus: section.settings.bar_3
          | plus: section.settings.bar_2
          | plus: section.settings.bar_1
        %}

        {% if total_hist == 0 %}
          {% assign total_hist = 1 %}
        {% endif %}

        {% assign stars = '5,4,3,2,1' | split: ',' %}
        {% for star in stars %}
          {% case star %}
            {% when '5' -%}
              {%- assign count = section.settings.bar_5 %}
            {% when '4' -%}
              {%- assign count = section.settings.bar_4 %}
            {% when '3' -%}
              {%- assign count = section.settings.bar_3 %}
            {% when '2' -%}
              {%- assign count = section.settings.bar_2 %}
            {% when '1' -%}
              {%- assign count = section.settings.bar_1 %}
          {% endcase %}

          {% assign width_pct = count | times: 100 | divided_by: total_hist %}

          <div class="nx-bb-reviews__hist-row">
            <span class="nx-bb-reviews__hist-label">{{ star }}</span>

            <div class="nx-bb-reviews__hist-bar">
              <span
                class="nx-bb-reviews__hist-fill"
                style="width: {{ width_pct }}%;"
              ></span>
            </div>

            <span class="nx-bb-reviews__hist-count">{{ count }}</span>
          </div>
        {% endfor %}
      </div>

      <div class="nx-bb-reviews__verified">
        {% if section.settings.verified_badge_text != blank %}
          <div class="nx-bb-reviews__verified-badge">
            {{ section.settings.verified_badge_text }}
          </div>
        {% endif %}
        <div class="nx-bb-reviews__total">
          {{ section.settings.total_reviews_label }}
        </div>
      </div>
    </div>

    {%- comment -%} SORT DROPDOWN + LIST {%- endcomment -%}
    <div class="nx-bb-reviews__sort-row">
      <span class="nx-bb-reviews__sort-label">
        {{ section.settings.sort_label }}
      </span>
    </div>

    <div class="nx-bb-reviews__list">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <article class="nx-bb-reviews__item" {{ block.shopify_attributes }}>
            <div class="nx-bb-reviews__item-header">
              <div class="nx-bb-reviews__item-name">
                {{ block.settings.name }}
              </div>
              <div class="nx-bb-reviews__item-date">
                {{ block.settings.date }}
              </div>
            </div>

            <div class="nx-bb-reviews__item-stars">
              {% for i in (1..block.settings.rating) %}
                ★
              {% endfor %}
            </div>

            {% if block.settings.title != blank %}
              <div class="nx-bb-reviews__item-title">
                {{ block.settings.title }}
              </div>
            {% endif %}

            {% if block.settings.body != blank %}
              <div class="nx-bb-reviews__item-body">
                {{ block.settings.body }}
              </div>
            {% endif %}

            {% if block.settings.photo != blank %}
              <div class="nx-bb-reviews__item-photo">
                {{
                  block.settings.photo
                  | image_url: width: 220
                  | image_tag: loading: 'lazy', alt: block.settings.title
                  | escape
                }}
              </div>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <div class="nx-bb-reviews__more-row">
      <button type="button" class="nx-bb-reviews__more-btn">
        {{ section.settings.show_more_label }}
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NX BB - Product reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "rating_line",
      "label": "Rating line",
      "default": "5.0 out of 5.0"
    },
    {
      "type": "text",
      "id": "rating_subline",
      "label": "Rating subline",
      "default": "Based on 28 reviews"
    },
    {
      "type": "range",
      "id": "bar_5",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "5-star reviews",
      "default": 20
    },
    {
      "type": "range",
      "id": "bar_4",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "4-star reviews",
      "default": 8
    },
    {
      "type": "range",
      "id": "bar_3",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "3-star reviews",
      "default": 0
    },
    {
      "type": "range",
      "id": "bar_2",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "2-star reviews",
      "default": 0
    },
    {
      "type": "range",
      "id": "bar_1",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "1-star reviews",
      "default": 0
    },
    {
      "type": "text",
      "id": "verified_badge_text",
      "label": "Verified badge text",
      "default": "Verified by Judge.me"
    },
    {
      "type": "text",
      "id": "total_reviews_label",
      "label": "Total reviews label",
      "default": "28 reviews"
    },
    {
      "type": "text",
      "id": "sort_label",
      "label": "Sort label",
      "default": "Most Recent"
    },
    {
      "type": "text",
      "id": "show_more_label",
      "label": "Show more button label",
      "default": "SHOW MORE"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "John M."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "12.12.2024"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating (1–5)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title",
          "default": "Perfect Flavor & Easy to Make!"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review text",
          "default": "I've made sausages before, but this kit made it incredibly simple. The seasoning is perfectly balanced—not too spicy, not too mild—and the casings were easy to work with. Everyone at my BBQ loved them! Highly recommend if you want to make high-quality brats at home."
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Review image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NX BB - Product reviews",
      "blocks": [{ "type": "review" }, { "type": "review" }, { "type": "review" }, { "type": "review" }]
    }
  ]
}
{% endschema %}
