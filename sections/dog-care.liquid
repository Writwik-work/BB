{%- style -%}

  /* Hide section on desktop if the setting is checked */

  {% if section.settings.hide_on_desktop %}

    @media screen and (min-width: 769px) {

      #shopify-section-{{ section.id }} {

        display: none !important;

      }

    }

  {% endif %}

  .cmh-container-{{ section.id }} {

    padding: 20px;

    display: flex;

    flex-direction: column;

    gap: 16px; /* Controls the space between the green box, button, and image */

    background-color: {{ section.settings.section_bg_color }};

    max-width: 768px;

    margin: 0 auto;

  }

  /* --- Top Card (Green Background) --- */

  .cmh-text-card {

    background-color: {{ section.settings.card_bg_color }};

    border-radius: 30px;

    padding: 30px 24px;

    display: flex;

    flex-direction: column;

  }

  .cmh-title {

    color: #155925;

    font-family: 'Mulish', sans-serif; 

    font-weight: 900;

    TEXT-TRANSFORM: NONE;

    font-size: 28px;

    line-height: 1.1;

    margin: 0 0 16px 0;

    letter-spacing: 0;

  }

  .cmh-description {

    color: #1a0f07;

    font-family: 'Mulish', sans-serif;

    font-weight: 500;

    font-size: 15px;

    line-height: 100%;

    margin: 0 0 20px 0;

  }

  /* --- Checklist --- */

  .cmh-list {

    list-style: none;

    padding: 0;

    margin: 0;

    display: flex;

    flex-direction: column;

    gap: 0px;

  }

  .cmh-list-item {

    display: flex;

    align-items: flex-start; /* Aligns icon with the top of multi-line text */

    gap: 8px;

    font-size: 15px;

    margin: 0;

    color: #1a0f07;

    font-family: 'Mulish', sans-serif;

    font-weight: 600;

    line-height: 1.3;

  }

  .cmh-list-icon {

    flex-shrink: 0; /* Prevents the icon from squishing */

    width: 16px;

    height: 16px;

    color: #155925;

    margin-top: 1px; /* Slight nudge to perfectly center with text */

  }

 
.cmh-list-item::before {

  content: "✔";

  left: 0;

  top: 0;

  color: #155925;

  font-size: 14px;

  line-height: 1.3;

}
 
  .cmh-button {

    display: flex;

    justify-content: center;

    align-items: center;

    background-color: #155925;

    color: #ffffff;

    text-decoration: none;

    padding: 16px 10px;

    border-radius: 10px;

    font-family: 'Mulish', sans-serif;

    font-weight: 900;

    font-size: 20px;

    text-transform: uppercase;

    letter-spacing: 5%;

    width: 100%;

    text-align: center;

    border: none;

    cursor: pointer;

  }

  /* --- Image --- */

  .cmh-image-wrapper {

    width: 100%;

    border-radius: 30px;

    overflow: hidden; /* This forces the image to respect the border-radius */

    display: flex;

  }

  .cmh-image {

    width: 100%;

    aspect-ratio: 4/4;

    height: auto;

    display: block;

    object-fit: cover;

  }

{%- endstyle -%}
<section class="cmh-container-{{ section.id }}">
<div class="cmh-text-card">

    {% if section.settings.title != blank %}
<h2 class="cmh-title">{{ section.settings.title }}</h2>

    {% endif %}

    {% if section.settings.description != blank %}
<div class="cmh-description">{{ section.settings.description }}</div>

    {% endif %}

    {% if section.blocks.size > 0 %}
<ul class="cmh-list">

        {% for block in section.blocks %}

          {% if block.settings.list_text != blank %}
<li class="cmh-list-item" {{ block.shopify_attributes }}>
<span>{{ block.settings.list_text }}</span>
</li>

          {% endif %}

        {% endfor %}
</ul>

    {% endif %}
</div>

  {% if section.settings.button_text != blank %}
<a href="{{ section.settings.button_link | default: '#' }}" class="cmh-button">

      {{ section.settings.button_text }}
</a>

  {% endif %}
<div class="cmh-image-wrapper">

    {% if section.settings.image != blank %}

      {{ section.settings.image | image_url: width: 800 | image_tag: class: 'cmh-image', loading: 'lazy' }}

    {% else %}

      {{ 'image' | placeholder_svg_tag: 'cmh-image' }}

    {% endif %}
</div>
</section>

{% schema %}

{

  "name": "care for dog mobile",

  "settings": [

    {

      "type": "checkbox",

      "id": "hide_on_desktop",

      "label": "Hide this section on Desktop view",

      "default": true

    },

    {

      "type": "color",

      "id": "section_bg_color",

      "label": "Outer Background Color",

      "default": "#ffffff"

    },

    {

      "type": "color",

      "id": "card_bg_color",

      "label": "Card Background Color (Light Green)",

      "default": "#BCD8C2"

    },

    {

      "type": "text",

      "id": "title",

      "label": "Heading",

      "default": "Grooming That Actually Cares for Your Dog"

    },

    {

      "type": "textarea",

      "id": "description",

      "label": "Description",

      "default": "Most grooming products clean, but strip, irritate, and dry out your dog's skin. Ruff Naturals is different. Every formula is designed to clean, soothe, and restore, so your dog looks good and feels comfortable."

    },

    {

      "type": "text",

      "id": "button_text",

      "label": "Button Text",

      "default": "MAKE BATH TIME BETTER ➔"

    },

    {

      "type": "url",

      "id": "button_link",

      "label": "Button Link"

    },

    {

      "type": "image_picker",

      "id": "image",

      "label": "Bottom Image"

    }

  ],

  "blocks": [

    {

      "type": "list_item",

      "name": "Checkmark Item",

      "settings": [

        {

          "type": "text",

          "id": "list_text",

          "label": "Text"

        }

      ]

    }

  ],

  "presets": [

    {

      "name": "care for dog mobile",

      "blocks": [

        { "type": "list_item", "settings": { "list_text": "Soothes itching & irritation" } },

        { "type": "list_item", "settings": { "list_text": "Supports healthy skin & coat" } },

        { "type": "list_item", "settings": { "list_text": "Safe for puppies & sensitive skin" } }

      ]

    }

  ]

}

{% endschema %}
 