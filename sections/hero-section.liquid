{{ 'hero-section.css' | asset_url | stylesheet_tag }}

<section
  id="section-{{ section.id }}"
  class="hero-section"
  style="background-image: url({{ 'hero/Hero-img.png' | asset_url }});"
>
  <div class="hero-section__overlay"></div>

  <div class="hero-section__inner page-width">
    {% if section.settings.heading != blank %}
      <h1 class="hero-section__heading">
        {{ section.settings.heading }}
      </h1>
    {% endif %}

    <div class="hero-section__buttons">
      {% if section.settings.primary_label != blank %}
        <a
          href="{{ section.settings.primary_link | default: '#' }}"
          class="hero-section__btn hero-section__btn--primary"
        >
          {{ section.settings.primary_label }}
        </a>
      {% endif %}

      {% if section.settings.secondary_label != blank %}
        <a
          href="{{ section.settings.secondary_link | default: '#' }}"
          class="hero-section__btn hero-section__btn--secondary"
        >
          {{ section.settings.secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ELEVATE THE MEAT EXPERIENCE"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "SHOP"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "LEARN"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero section"
    }
  ]
}
{% endschema %}
