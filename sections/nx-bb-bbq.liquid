{{ 'nx-bb-bbq.css' | asset_url | stylesheet_tag }}

<section
  id="section-{{ section.id }}"
  class="nx-section nx-bb-bbq section-{{ section.id }}"
>
  <div class="container">
    <div class="nx-bb-bbq__header-row">
      {% if section.settings.heading != blank %}
        <h2 class="nx-bb-bbq__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.shop_all_label != blank %}
        <a
          href="{{ section.settings.shop_all_link | default: '#' }}"
          class="nx-bb-bbq__shop-all"
        >
          {{ section.settings.shop_all_label }}
        </a>
      {% endif %}
    </div>

    <div class="nx-bb-bbq__grid">
      {%- for i in (1..3) -%}
        {%- assign title_id = 'title_' | append: i -%}
        {%- assign price_id = 'price_' | append: i -%}
        {%- assign compare_id = 'compare_price_' | append: i -%}
        {%- assign reviews_id = 'reviews_text_' | append: i -%}

        {%- case i -%}
          {%- when 1 -%}
            {%- assign asset_path = 'bbq/grilling.jpg' -%}
          {%- when 2 -%}
            {%- assign asset_path = 'bbq/pitmaster.png' -%}
          {%- when 3 -%}
            {%- assign asset_path = 'bbq/backyard.png' -%}
        {%- endcase -%}

        <div class="nx-bb-bbq__card">
          <div class="nx-bb-bbq__image-wrapper">
            <img
              src="{{ asset_path | asset_url }}"
              alt="{{ section.settings[title_id] }}"
              loading="lazy"
              class="nx-bb-bbq__image"
            >
          </div>

          <div class="nx-bb-bbq__meta">
            <p class="nx-bb-bbq__vendor">The Bearded Butchers</p>

            {% if section.settings[title_id] != blank %}
              <h3 class="nx-bb-bbq__title">
                {{ section.settings[title_id] }}
              </h3>
            {% endif %}

            <div class="nx-bb-bbq__rating-row">
              <span class="nx-bb-bbq__stars">★★★★★</span>
              {% if section.settings[reviews_id] != blank %}
                <span class="nx-bb-bbq__reviews">
                  {{ section.settings[reviews_id] }}
                </span>
              {% endif %}
            </div>

            <div class="nx-bb-bbq__price-row">
              {% if section.settings[price_id] != blank %}
                <span class="nx-bb-bbq__price">
                  {{ section.settings[price_id] }}
                </span>
              {% endif %}

              {% if section.settings[compare_id] != blank %}
                <span class="nx-bb-bbq__compare">
                  {{ section.settings[compare_id] }}
                </span>
              {% endif %}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NX – BB BBQ Bundles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GRILL LIKE A PRO – TOOLS FOR THE PERFECT COOK"
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "\"Shop all\" label",
      "default": "SHOP ALL"
    },
    {
      "type": "url",
      "id": "shop_all_link",
      "label": "\"Shop all\" link"
    },

    { "type": "text", "id": "title_1", "label": "Card 1 title", "default": "GRILLING GURU BBQ BUNDLE" },
    { "type": "text", "id": "price_1", "label": "Card 1 price", "default": "$349.00" },
    { "type": "text", "id": "compare_price_1", "label": "Card 1 compare-at price", "default": "$349.00" },
    { "type": "text", "id": "reviews_text_1", "label": "Card 1 reviews text", "default": "29 Reviews" },

    { "type": "text", "id": "title_2", "label": "Card 2 title", "default": "PITMASTER PRO BBQ BUNDLE" },
    { "type": "text", "id": "price_2", "label": "Card 2 price", "default": "$349.00" },
    { "type": "text", "id": "compare_price_2", "label": "Card 2 compare-at price", "default": "$349.00" },
    { "type": "text", "id": "reviews_text_2", "label": "Card 2 reviews text", "default": "29 Reviews" },

    { "type": "text", "id": "title_3", "label": "Card 3 title", "default": "BACKYARD BBQ'ER BUNDLE" },
    { "type": "text", "id": "price_3", "label": "Card 3 price", "default": "$349.00" },
    { "type": "text", "id": "compare_price_3", "label": "Card 3 compare-at price", "default": "$349.00" },
    { "type": "text", "id": "reviews_text_3", "label": "Card 3 reviews text", "default": "29 Reviews" }
  ],
  "presets": [
    {
      "name": "NX – BB BBQ Bundles"
    }
  ]
}
{% endschema %}
