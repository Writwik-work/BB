{% comment %}
  Hero: text left, image right (Unbottle Laundry style)
{% endcomment %}

<section
  id="section-{{ section.id }}"
  class="hero-text-image section-{{ section.id }}-padding"
  style="
    --section-bg: {{ section.settings.section_bg }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --primary-bg: {{ section.settings.primary_button_bg }};
    --primary-bg-hover: {{ section.settings.primary_button_bg_hover }};
    --primary-text: {{ section.settings.primary_button_text }};
    --secondary-text: {{ section.settings.secondary_button_text }};
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="page-width hero-text-image__inner">
    <div class="hero-text-image__content">
      {% if section.settings.heading != blank %}
        <h2 class="hero-text-image__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="hero-text-image__subheading">
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      {% if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank %}
        <div class="hero-text-image__buttons">
          {% if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank %}
            <a
              href="{{ section.settings.primary_button_link }}"
              class="hero-text-image__button hero-text-image__button--primary"
            >
              {{ section.settings.primary_button_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank %}
            <a
              href="{{ section.settings.secondary_button_link }}"
              class="hero-text-image__button hero-text-image__button--secondary"
            >
              {{ section.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if section.settings.image != blank %}
      <div class="hero-text-image__media">
        {%- assign hero_image = section.settings.image -%}
        {%- assign image_alt = hero_image.alt | default: section.settings.heading | escape -%}
        {%- assign widths = '360, 535, 720, 900, 1200, 1440' -%}
        {%- capture sizes -%}
          (min-width: 1200px) 560px,
          (min-width: 750px) 50vw,
          100vw
        {%- endcapture -%}

        {{
          hero_image
          | image_url: width: 1440
          | image_tag: loading: 'lazy', widths: widths, sizes: sizes, alt: image_alt
        }}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #section-{{ section.id }} {
    background-color: var(--section-bg);
  }

  .section-{{ section.id }}-padding {
    padding-top: var(--pt-mobile);
    padding-bottom: var(--pb-mobile);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: var(--pt-desktop);
      padding-bottom: var(--pb-desktop);
    }
  }

  /* === LAYOUT === */
  #section-{{ section.id }} .hero-text-image__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 36px;
    align-items: center;
    margin: 0 80px;
  }

  @media screen and (max-width: 749px) {
    #section-{{ section.id }} .hero-text-image__inner {
      grid-template-columns: 1fr;
      margin: 0 20px;
      text-align: center;
    }
  }

  #section-{{ section.id }} .hero-text-image__content {
    max-width: 620px;
  }

  @media screen and (max-width: 749px) {
    #section-{{ section.id }} .hero-text-image__content {
      margin: 0 auto;
    }
  }

  /* === TEXT === */
  #section-{{ section.id }} .hero-text-image__heading {
    margin: 0 0 16px;
    font-family: Montserrat;
    font-weight: 500;
    font-size: 42px;
    line-height: 50px;
    color: var(--heading-color);
  }

  @media screen and (min-width: 990px) {
    #section-{{ section.id }} .hero-text-image__heading {
      font-size: 44px;
    }
  }

  @media screen and (max-width: 749px) {
    #section-{{ section.id }} .hero-text-image__heading {
      text-align: center;
    }
  }

  #section-{{ section.id }} .hero-text-image__subheading {
    margin: 0 0 28px;
    font-family: Montserrat;
    font-weight: 400;
    font-size: 18px;
    line-height: 26px;
    color: var(--text-color);
  }

  @media screen and (max-width: 749px) {
    #section-{{ section.id }} .hero-text-image__subheading {
      text-align: center;
    }
  }

  /* === BUTTONS === */
  #section-{{ section.id }} .hero-text-image__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 24px;
    align-items: center;
  }

  @media screen and (max-width: 749px) {
    #section-{{ section.id }} .hero-text-image__buttons {
      justify-content: center;
    }
  }

  #section-{{ section.id }} .hero-text-image__button {
    font-family: Montserrat;
    font-weight: 500;
    font-size: 16px;
    line-height: 21px;
    text-decoration: none;
    cursor: pointer;
  }

  #section-{{ section.id }} .hero-text-image__button--primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 34px;
    border-radius: 60px;
    background-color: var(--primary-bg);
    color: var(--primary-text);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
    transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }

  @media screen and (max-width: 749px) {
    #section-{{ section.id }} .hero-text-image__button--primary {
      width: 100%;
      max-width: 280px;
      min-width: 220px;
    }
  }

  #section-{{ section.id }} .hero-text-image__button--primary:hover {
    background-color: var(--primary-bg-hover);
    transform: translateY(-1px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.16);
  }

  #section-{{ section.id }} .hero-text-image__button--primary:focus-visible {
    outline: 2px solid var(--primary-bg-hover);
    outline-offset: 3px;
  }

  #section-{{ section.id }} .hero-text-image__button--secondary {
    color: var(--secondary-text);
    text-decoration: underline;
    font-family: Montserrat;
    font-weight: 500;
    font-size: 16px;
    line-height: 21px;
    text-underline-offset: 3px;
  }

  #section-{{ section.id }} .hero-text-image__button--secondary:hover {
    text-decoration-thickness: 2px;
  }

  /* === IMAGE === */
  #section-{{ section.id }} .hero-text-image__media {
    border-radius: 16px;
    overflow: hidden;
    max-width: 610px;
    width: 100%;
    height: 360px;
    margin-left: auto;
  }

  @media screen and (max-width: 749px) {
    #section-{{ section.id }} .hero-text-image__media {
      max-width: 100%;
      height: auto;
      margin: 24px auto 0;
      /* no order change – image stays AFTER text */
    }
  }

  #section-{{ section.id }} .hero-text-image__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>


{% schema %}
{
  "name": "Hero - text with image",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Movement to Unbottle Laundry"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every wash matters. Ditch plastic bottles, protect the planet, and experience a cleaner, simpler way to do laundry — powered by nature and proven by science."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "For Wholesale Buyers"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#FDF7EE"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#3c572a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "primary_button_bg",
      "label": "Primary button background",
      "default": "#31542B"
    },
    {
      "type": "color",
      "id": "primary_button_bg_hover",
      "label": "Primary button background (hover)",
      "default": "#274422"
    },
    {
      "type": "color",
      "id": "primary_button_text",
      "label": "Primary button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "secondary_button_text",
      "label": "Secondary button text color",
      "default": "#31542B"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Hero - text with image"
    }
  ]
}
{% endschema %}
