{%- style -%}
  /* Base Desktop Styles (Default - Active down to 1025px) */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }
 
 
#shopify-section-{{ section.id }}.shopify-section.section {
  max-width: 100% !important;
  width: 100% !important;
  margin: 0 !important;
}
  .guarantee-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 60px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    flex-wrap: nowrap;
    gap: 40px;
  }
  .guarantee-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    max-width: 676px;
    flex: 1 1 55%;
  }
  .guarantee-title {
    color: {{ section.settings.title_color }};
    font-family: Mulish;
    font-weight: 900;
    text-transform:none;
    font-size: 52px;
    line-height: 100%;
    letter-spacing: 0%;
    vertical-align: middle;
    margin-top: 0;
    margin-bottom: 24px;
  }
  .guarantee-text {
    color: #1A0F07;
    font-family: Mulish;
    font-weight: 700;
    font-size: 24px;
    line-height: 140%;
    letter-spacing: 0%;
  }
  .guarantee-text strong {
    color: #155925;
  }
  .guarantee-text p:not(:first-child) strong {
    color: #333333;
  }
  .guarantee-text p {
    font-family: Mulish;
    font-weight: 500;
    font-size: 24px;
    line-height: 140%;
    letter-spacing: 0%;
    margin-top: 0;
    margin-bottom: 20px;
  }
  .guarantee-text p:last-child {
    margin-bottom: 0;
  }
  .guarantee-media {
    flex: 1 1 45%;
    display: flex;
    justify-content: flex-end;
  }
  .guarantee-image-wrapper {
    display: grid;
    width: 100%;
    max-width: 549px;
  }
  .guarantee-main-img-container {
    grid-area: 1 / 1 / 2 / 2;
    width: 100%;
    height: auto;
    aspect-ratio: 549 / 614;
    border-radius: 30px;
    overflow: hidden;
  }
  .guarantee-main-img,
  .guarantee-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale({{ section.settings.image_zoom }});
    transform-origin: center center;
    transition: transform 0.3s ease;
  }
  .guarantee-placeholder {
    background-color: #f3f3f3;
    fill: #cccccc;
  }
  .guarantee-badge-img {
    grid-area: 1 / 1 / 2 / 2;
    align-self: end;
    justify-self: start;
    width: 242px;
    height: 242px;
    transform: translate(-50%, 0%);
    z-index: 2;
  }
  /* Mid-range Viewport (1300px to 1025px) */
  @media screen and (min-width: 1025px) and (max-width: 1390px) {
    .guarantee-container {
      padding: 0 40px;
      gap: 0px;
    }
    .guarantee-content {
      max-width: 676px;
      flex: 1 1 50%;
    }
    .guarantee-title {
      font-size: 40px;
    }
    .guarantee-text p {
      font-size: 18px;
    }
    .guarantee-text {
      font-size: 18px;
    }
    .guarantee-media {
      flex: 1 1 50%;
      justify-content: flex-end;
    }
    .guarantee-image-wrapper {
      max-width: 440px;
    }
    .guarantee-badge-img {
      width: 160px;
      height: 160px;
      transform: translate(-40%, 0%);
    }
  }
  /* Tablet Viewport (1024px and below) */
  @media screen and (max-width: 1024px) {
    .guarantee-container {
      flex-direction: column-reverse;
      align-items: center;
      padding: 0 40px;
      gap: 50px;
    }
    .guarantee-content {
      max-width: 100%;
      flex: 1 1 auto;
      justify-content: flex-start;
    }
    .guarantee-title {
      font-size: 40px;
    }
    .guarantee-media {
      width: 100%;
      justify-content: center;
    }
    .guarantee-image-wrapper {
      max-width: fit-content;
    }
    .guarantee-main-img-container {
      height: auto;
      aspect-ratio: 1 / 1;
    }
    .guarantee-badge-img {
      width: 242px;
      height: 242px;
      transform: translate(-25%, -28%);
    }
  }
  /* Mobile Viewport (768px and below) */
  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .guarantee-container {
      flex-direction: column-reverse; /* Puts image above the text */
      padding: 0 20px;
      gap: 24px;
    }
    .guarantee-title {
      font-size: 28px; /* Scaled down for mobile */
      margin-bottom: 16px;
              text-transform: none;
    }
    .guarantee-text,
    .guarantee-text p {
      font-size: 15px; /* Matches screenshot text size */
      line-height: 140%;
      margin-bottom: 16px;
    }
    /* Hides the second paragraph on mobile */
    .guarantee-text p:last-child {
      display: none;
    }
    .guarantee-media {
      padding-left: 0;
      width: 100%;
    }
    .guarantee-image-wrapper {
      max-width: 100%; /* Allows image to fill container width */
      width: 100%;
    }
    .guarantee-main-img-container {
      aspect-ratio: 4 / 3; /* Creates the landscape rectangle look */
      border-radius: 16px; /* Slightly softer corners on mobile */
    }
    .guarantee-badge-img {
      width: 120px;
      height: 120px;
      justify-self: end; /* Pins badge to the right */
      align-self: end; /* Pins badge to the bottom */
      transform: translate(15%, 25%); /* Pushes it just over the bottom-right edge */
    }
  }
{%- endstyle -%}
<section class="section-{{ section.id }}-padding">
<div class="guarantee-container">
<div class="guarantee-content">
      {%- if section.settings.title != blank -%}
<h2 class="guarantee-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
<div class="guarantee-text">
          {{ section.settings.text }}
</div>
      {%- endif -%}
</div>
<div class="guarantee-media">
<div class="guarantee-image-wrapper">
<div class="guarantee-main-img-container">
          {%- if section.settings.main_image != blank -%}
            {{ section.settings.main_image | image_url: width: 1100 | image_tag: class: 'guarantee-main-img', loading: 'lazy', alt: "dog with shampoo"}}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'guarantee-placeholder' }}
          {%- endif -%}
</div>
        {%- if section.settings.badge_image != blank -%}
          {{ section.settings.badge_image | image_url: width: 484 | image_tag: class: 'guarantee-badge-img', loading: 'lazy', alt: section.settings.badge_image.alt | escape }}
        {%- endif -%}
</div>
</div>
</div>
</section>
{% schema %}
{
  "name": "Money Back Guarantee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "90 Day Money Back Guarantee"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading Color",
      "default": "#155925"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>We’re so confident you’ll love how Ruff Naturals™ cares for your dog's skin and coat that every purchase is backed by our full <strong>90-Day Money Back Guarantee</strong>. If for any reason you’re not completely satisfied—whether it’s the feel of their coat, the freshness, or the results on sensitive skin—you can return it, no questions asked.</p><p>With <strong>Ruff Naturals™</strong>, you have nothing to lose and your dog has healthier skin, a softer coat, and long-lasting comfort to gain.</p>"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "range",
      "id": "image_zoom",
      "min": 1.0,
      "max": 2.0,
      "step": 0.1,
      "label": "Main Image Zoom",
      "default": 1.2,
      "info": "Scale the image to match the tight crop of the design."
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge Image (Overlay)"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Money Back Guarantee"
    }
  ]
}
{% endschema %}